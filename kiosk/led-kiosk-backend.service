# Install: sudo cp led-kiosk-backend.service /etc/systemd/system/
#          sudo systemctl enable --now led-kiosk-backend
[Unit]
Description=LED kiosk FastAPI backend
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=pi4
WorkingDirectory=/home/pi4/led-kiosk
ExecStart=/home/pi4/led-kiosk/venv/bin/uvicorn app.main:app --host 127.0.0.1 --port 8000
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
