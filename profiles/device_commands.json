{
  "device_name": "Columna RGB",
  "notes": "Commands are 3 letters + value, no separators, sent UPPERCASE over MQTT (e.g. FRM5, BRI70, PPCFF0000). The backend builds and uppercases the final string -- the UI only needs to collect the value.",
  "commands": [
    {
      "id": "FRM",
      "label": "Mostrar cuadro",
      "value_type": "number",
      "min": 1,
      "note": "Actualizar 'min'/'max' cuando se sepa cuántos cuadros hay cargados en el dispositivo."
    },
    {
      "id": "BRI",
      "label": "Brillo",
      "value_type": "slider",
      "min": 0,
      "max": 100,
      "default": 70,
      "unit": "%"
    },
    {
      "id": "BLK",
      "label": "Parpadeo",
      "value_type": "number",
      "min": 0,
      "unit": "ms",
      "note": "0 = apagado"
    },
    {
      "id": "ROT",
      "label": "Velocidad de rotación",
      "value_type": "number",
      "min": 0,
      "unit": "ms",
      "note": "0 = apagado (efecto de desplazamiento)"
    },
    {
      "id": "INV",
      "label": "Invertir dirección de rotación",
      "value_type": "none"
    },
    {
      "id": "AUT",
      "label": "Reanudar modo automático",
      "value_type": "none"
    },
    {
      "id": "STA",
      "label": "Solicitar estado",
      "value_type": "none"
    },
    {
      "id": "PPG",
      "label": "Modo ping-pong",
      "value_type": "toggle"
    },
    {
      "id": "PPC",
      "label": "Color de la pelota (ping-pong)",
      "value_type": "hex_color",
      "default": "#FF0000"
    },
    {
      "id": "PPK",
      "label": "Color de fondo (ping-pong)",
      "value_type": "hex_color",
      "default": "#0000FF"
    },
    {
      "id": "NET",
      "label": "Deshabilitar red (solo SMS después)",
      "value_type": "none",
      "fixed_value": "0",
      "confirm": true,
      "confirm_text": "Esto deshabilita MQTT en el dispositivo de inmediato. Solo puede reactivarse enviando NET1 por SMS desde un número autorizado, no desde esta app. ¿Continuar?"
    }
  ]
}
