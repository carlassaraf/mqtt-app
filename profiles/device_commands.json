{
  "device_name": "Columna RGB",
  "notes": "Commands are 3 letters + value, no separators, sent UPPERCASE over MQTT (e.g. FRM5, BRI70, PPCFF0000). The backend builds and uppercases the final string -- the UI only needs to collect the value.",
  "commands": [
    {
      "id": "FRM",
      "label": "Mostrar escena",
      "value_type": "number",
      "min": 1,
      "max": 22
    },
    {
      "id": "BRI",
      "label": "Brillo",
      "value_type": "slider",
      "min": 0,
      "max": 100,
      "default": 70,
      "unit": "%"
    },
    {
      "id": "BLK",
      "label": "Parpadeo",
      "value_type": "number",
      "min": 0,
      "unit": "ms",
      "note": "0 = apagado"
    },
    {
      "id": "ROT",
      "label": "Velocidad de rotación",
      "value_type": "number",
      "min": 0,
      "unit": "ms",
      "note": "0 = apagado (efecto de desplazamiento)"
    },
    {
      "id": "INV",
      "label": "Invertir dirección de rotación",
      "value_type": "none"
    },
    {
      "id": "AUT",
      "label": "Reanudar modo automático",
      "value_type": "none"
    },
    {
      "id": "STA",
      "label": "Solicitar estado",
      "value_type": "none"
    },
    {
      "id": "PPG",
      "label": "Modo ping-pong",
      "value_type": "toggle"
    },
    {
      "id": "PPC",
      "label": "Color de la pelota (ping-pong)",
      "value_type": "hex_color",
      "default": "#FF0000"
    },
    {
      "id": "PPK",
      "label": "Color de fondo (ping-pong)",
      "value_type": "hex_color",
      "default": "#0000FF"
    },
    {
      "id": "SCR",
      "label": "Modo rotación de color por tira",
      "value_type": "toggle"
    },
    {
      "id": "SCL",
      "label": "Colores de las tiras",
      "value_type": "hex_color_triple",
      "defaults": ["#FF0000", "#00FF00", "#0000FF"],
      "palette": [
        "#FF0000", "#00FF00", "#0000FF", "#FFFF00",
        "#FF00FF", "#00FFFF", "#FFFFFF", "#FFA500",
        "#800080", "#000000"
      ]
    },
    {
      "id": "OUT",
      "label": "Indicador LED de estado",
      "value_type": "toggle",
      "note": "LED de estado del dispositivo, no las tiras RGB"
    }
  ]
}
